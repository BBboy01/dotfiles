{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": ["oh-my-opencode"],
  "mcp": {
    "gitnexus": {
      "type": "local",
      "command": ["npx", "-y", "gitnexus@latest", "mcp"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--no-usage-statistics"
      ]
    },
    "playwright": {
      "type": "local",
      "command": ["bunx", "@playwright/mcp@latest"]
    }
  }
}
